font_size 12
include themes/cyberdream.conf

hide_window_decorations yes
disable_ligatures always


# BEGIN_KITTY_THEME
# Solarized8 Dark
include current-theme.conf
# END_KITTY_THEME


# BEGIN_KITTY_FONTS
font_family      family="MartianMonoNerdFont"
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS
